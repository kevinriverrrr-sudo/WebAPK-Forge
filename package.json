{
  "name": "webapk-forge",
  "version": "1.0.0",
  "description": "Professional CLI Android WebView APK Builder for Termux. Build APK apps from any website URL directly on your Android device. No Android SDK required.",
  "main": "src/index.js",
  "bin": {
    "webapk": "bin/webapk.js"
  },
  "scripts": {
    "start": "node bin/webapk.js",
    "setup": "node src/setup.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "tools/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "android",
    "apk",
    "apk-builder",
    "builder",
    "cli",
    "java",
    "kotlin",
    "mobile",
    "no-sdk",
    "termux",
    "webview",
    "webview-app"
  ],
  "author": "WebAPK Forge Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinriverrrr-sudo/WebAPK-Forge.git"
  },
  "bugs": {
    "url": "https://github.com/kevinriverrrr-sudo/WebAPK-Forge/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "preferGlobal": true
}
